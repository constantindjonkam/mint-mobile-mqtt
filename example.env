# ==========================================
# Mint Mobile Credentials
# ==========================================
MINT_PHONE=XXXXXXXXXX               # Your 10-digit Mint Mobile phone number
MINT_PASSWORD=your_password_here    # Your Mint Mobile login password

# ==========================================
# MQTT Broker Settings
# ==========================================
MQTT_URL=mqtt://localhost:1883       # Broker connection URL (e.g., mqtt://192.168.1.50:1883)
MQTT_USER=                           # Optional: Username for MQTT broker authentication
MQTT_PASS=                           # Optional: Password for MQTT broker authentication

# ==========================================
# Home Assistant & Discovery Settings
# ==========================================
MQTT_PREFIX=mintmobile               # Topic prefix for publishing states (default: mintmobile)
MQTT_DISCOVERY=true                  # Enable Home Assistant auto-discovery (true/false)
MQTT_DISCOVERY_PREFIX=homeassistant  # Home Assistant discovery topic prefix (default: homeassistant)

# ==========================================
# Daemon Settings
# ==========================================
POLL_INTERVAL_MINS=720               # Frequency to fetch and publish data in minutes (minimum: 60)
